<view class="container">
  <view class="result-icon">{{result && result.won ? '🎉' : '😅'}}</view>
  <view class="result-title">{{result && result.won ? '你赢了！' : '再接再厉'}}</view>

  <view class="score-card card">
    <view class="row" wx:for="{{result.scores}}" wx:key="index">
      <text>{{item.name}}</text>
      <text class="{{item.score >= 0 ? 'green' : 'red'}}">
        {{item.score >= 0 ? '+' : ''}}{{item.score}}
      </text>
    </view>
  </view>

  <view class="btns">
    <button class="btn-primary" bindtap="playAgain">再来一局</button>
    <button class="btn-secondary" bindtap="goHome">返回首页</button>
  </view>
</view>
