.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0b1a2e 0%, #122844 50%, #0b1a2e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #64b5f6;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
}

.card-display {
  display: flex;
  gap: 16rpx;
  margin-bottom: 50rpx;
}

.card-display .card {
  width: 80rpx;
  height: 112rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.4);
  transform: rotate(var(--r, 0deg));
}

.c1 { background: #fff; color: #212121; transform: rotate(-15deg); }
.c2 { background: #fff; color: #d32f2f; transform: rotate(-5deg); }
.c3 { background: #fff; color: #d32f2f; transform: rotate(5deg); }
.c4 { background: #fff; color: #212121; transform: rotate(15deg); }

.menu {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.menu-btn {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  border: none;
  text-align: left;
  width: 100%;
}

.ai-btn {
  background: linear-gradient(135deg, rgba(33,150,243,0.7), rgba(25,118,210,0.5));
  border: 1rpx solid rgba(33,150,243,0.3);
}

.online-btn {
  background: linear-gradient(135deg, rgba(21,101,192,0.8), rgba(25,118,210,0.6));
  border: 1rpx solid rgba(25,118,210,0.3);
}

.rules-btn {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
}

.btn-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.btn-text {
  flex: 1;
}

.btn-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 4rpx;
}

.btn-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}

.footer {
  margin-top: 60rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}
