.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex; align-items: center; justify-content: center;
  z-index: 999;
}

.popup-content {
  background: #112233;
  border-radius: 22rpx;
  padding: 32rpx;
  width: 85%;
  max-width: 560rpx;
}

.heaven-section {
  text-align: center;
  margin-bottom: 20rpx;
}
.heaven-icon  { font-size: 56rpx; margin-bottom: 10rpx; }
.heaven-title { font-size: 32rpx; font-weight: bold; color: #64b5f6; margin-bottom: 6rpx; }
.heaven-player { font-size: 24rpx; color: #8ab4d8; }

.result-title {
  font-size: 28rpx; font-weight: bold; color: #fff;
  text-align: center; margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.player-scores { margin-bottom: 24rpx; }

.score-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.score-name  { flex: 1; font-size: 24rpx; color: #c8d8e8; }
.score-cards { font-size: 20rpx; color: #6a8aa8; margin: 0 8rpx; }
.score-detail { font-size: 20rpx; color: #8ab4d8; }
.score-value  { font-size: 26rpx; font-weight: bold; }
.score-value.positive { color: #4caf50; }
.score-value.negative { color: #f44336; }

.btn-group {
  display: flex; gap: 16rpx;
}
.btn {
  flex: 1; padding: 16rpx 0; border-radius: 14rpx;
  font-size: 24rpx; border: none;
}
.btn-continue {
  background: #2196f3;
  color: #fff;
}
.btn-back {
  background: rgba(255,255,255,0.08);
  color: #8ab4d8;
}
