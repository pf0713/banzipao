.action-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 6rpx 24rpx 10rpx;
  background: rgba(0,0,0,0.35);
  flex-shrink: 0;
}
.selected-info {
  font-size: 18rpx;
  color: #64b5f6;
  white-space: nowrap;
  min-width: 80rpx;
}
.btn-row {
  display: flex;
  gap: 10rpx;
}
.btn {
  padding: 10rpx 28rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: bold;
  border: none;
}
.btn-play {
  background: linear-gradient(135deg, #2196f3, #1565c0);
  color: #fff;
}
.btn-play[disabled] {
  background: rgba(255,255,255,0.08);
  color: #445a6e;
}
.btn-pass {
  background: rgba(255,255,255,0.1);
  color: #c8d8e8;
  border: 1rpx solid rgba(255,255,255,0.15);
}
.btn-pass[disabled] { opacity: 0.3; }
.btn-hint {
  background: rgba(100,181,246,0.2);
  color: #64b5f6;
  border: 1rpx solid rgba(100,181,246,0.3);
}
